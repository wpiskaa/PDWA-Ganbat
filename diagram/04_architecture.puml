@startuml 04_Architecture_Diagram
title Ganbat — Arsitektur Sistem (MVC-like PHP)

skinparam backgroundColor #1E1E2E
skinparam componentBorderColor #7C6AF5
skinparam componentBackgroundColor #2A2A3E
skinparam componentFontColor #CCCCFF
skinparam packageBorderColor #555577
skinparam packageBackgroundColor #22223A
skinparam packageFontColor #AAAACC
skinparam databaseBorderColor #7C6AF5
skinparam databaseBackgroundColor #2A2A3E
skinparam databaseFontColor #CCCCFF
skinparam arrowColor #7C6AF5
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam noteBorderColor #7C6AF5
skinparam noteBackgroundColor #2E2E45
skinparam noteFontColor #CCCCFF

' =============================================
' LAYER 1 — CLIENT / BROWSER
' =============================================
package "Client Layer" <<Browser>> {
  [Web Browser] as Browser
  note right of Browser
    HTTP GET / POST Request
    Session Cookie
  end note
}

' =============================================
' LAYER 2 — PUBLIC / ENTRY POINT
' =============================================
package "Public Layer (Entry Point)\n/public" {
  [login.php\n(Form Login)] as LoginPage
  [register.php\n(Form Register)] as RegisterPage
  [index.php\n(Kanban Board)] as IndexPage

  package "Assets" {
    [css/style.css] as CSS
    [js/main.js] as MainJS
    [js/countdown.js] as CountdownJS
  }
}

' =============================================
' LAYER 3 — CONTROLLER
' =============================================
package "Controller Layer\n/src/controllers" {
  [AuthController.php\nhandleLogin()\nhandleRegister()\nhandleLogout()] as AuthCtrl
  [TaskController.php\ncreateTask()\nupdateTaskStatus()\nassignMemberToTask()] as TaskCtrl
  [CommentController.php\nhandlePost()\ngetCommentsByTask()] as CommentCtrl
}

' =============================================
' LAYER 4 — VIEW COMPONENTS
' =============================================
package "View Layer\n/src/views" {
  package "Layouts" {
    [header.php] as Header
    [footer.php] as Footer
  }
  package "Components" {
    [navbar.php] as Navbar
    [board_column.php] as BoardCol
    [task_card.php] as TaskCard
    [comment_section.php] as CommentSec
  }
}

' =============================================
' LAYER 5 — CONFIG & UTILS
' =============================================
package "Config & Utils Layer\n/src" {
  [config/database.php\n$pdo = new PDO()] as DBConfig
  [utils/helpers.php\ngetDeadlineStatus()\ngetDeadlineClasses()\nformatDeadlineDate()\ngetPriorityClasses()\ngetStatusClasses()] as Helpers
}

' =============================================
' LAYER 6 — DATABASE
' =============================================
database "MySQL Database\n(ganbat)" as MySQL {
  [users] as TUsers
  [tasks] as TTasks
  [task_assignees] as TAssign
  [comments] as TComments
}

' =============================================
' KONEKSI ANTAR LAYER
' =============================================

' Browser ke Public
Browser --> LoginPage     : HTTP Request
Browser --> RegisterPage  : HTTP Request
Browser --> IndexPage     : HTTP Request
IndexPage --> CSS
IndexPage --> MainJS
IndexPage --> CountdownJS

' Public ke Controller
LoginPage    --> AuthCtrl    : POST action=login/register/logout
RegisterPage --> AuthCtrl    : POST action=register
IndexPage    --> TaskCtrl    : POST action=create/update/assign
IndexPage    --> CommentCtrl : POST (comment)

' Public ke View
IndexPage --> Header
IndexPage --> Footer
IndexPage --> Navbar
IndexPage --> BoardCol
BoardCol  --> TaskCard
TaskCard  --> CommentSec

' Controller ke Config
AuthCtrl    --> DBConfig : require_once
TaskCtrl    --> DBConfig : require_once
CommentCtrl --> DBConfig : require_once

' View ke Helpers
TaskCard  --> Helpers : getDeadlineStatus()\ngetDeadlineClasses()
IndexPage --> Helpers : formatDeadlineDate()

' Config ke Database
DBConfig --> MySQL : PDO Connection\nmysql:host=localhost\ndbname=ganbat

' Controller ke Database
AuthCtrl    --> TUsers   : SELECT / INSERT
TaskCtrl    --> TTasks   : INSERT / UPDATE
TaskCtrl    --> TAssign  : DELETE / INSERT
CommentCtrl --> TComments : INSERT / SELECT
IndexPage   --> TTasks   : SELECT (direct query)
IndexPage   --> TAssign  : SELECT JOIN users

' Controller kembali ke Browser
AuthCtrl    --> Browser : header(Location: ...)
TaskCtrl    --> Browser : header(Location: ...)
CommentCtrl --> Browser : header(Location: ...)

@enduml
